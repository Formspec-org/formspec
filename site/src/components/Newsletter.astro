---
// Newsletter signup — submits to /api/subscribe (Firebase Function → Resend).

export interface Props {
  /** "inline" renders compact (for CTA sections), "stacked" renders with heading (for footer) */
  variant?: "inline" | "stacked";
}

const { variant = "stacked" } = Astro.props;
---

<div class={`newsletter newsletter--${variant}`}>
  {variant === "stacked" && (
    <div class="newsletter-text">
      <p class="newsletter-label">Stay in the loop</p>
      <p class="newsletter-desc">Spec updates, new features, and the occasional design deep dive. No spam.</p>
    </div>
  )}
  {variant === "inline" && (
    <p class="newsletter-inline-label">Get spec updates and new feature announcements:</p>
  )}
  <form class="newsletter-form" data-newsletter>
    <label for={`newsletter-email-${variant}`} class="sr-only">Email address</label>
    <input
      type="email"
      name="email"
      id={`newsletter-email-${variant}`}
      placeholder="you@example.com"
      required
      autocomplete="email"
      class="newsletter-input"
    />
    <button type="submit" class="newsletter-btn">
      <span class="newsletter-btn-text">Subscribe</span>
    </button>
    <p class="newsletter-status" aria-live="polite"></p>
  </form>
</div>

<script>
  document.querySelectorAll("[data-newsletter]").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.currentTarget as HTMLFormElement;
      const input = f.querySelector("input[name=email]") as HTMLInputElement;
      const btn = f.querySelector(".newsletter-btn") as HTMLButtonElement;
      const btnText = f.querySelector(".newsletter-btn-text") as HTMLElement;
      const status = f.querySelector(".newsletter-status") as HTMLElement;
      const email = input.value.trim();

      if (!email) return;

      btn.disabled = true;
      btnText.textContent = "Sending...";
      status.textContent = "";
      status.className = "newsletter-status";

      try {
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });

        if (res.ok) {
          btnText.textContent = "Subscribed!";
          status.textContent = "You're in. We'll keep it useful.";
          status.classList.add("newsletter-status--ok");
          input.value = "";
          setTimeout(() => {
            btnText.textContent = "Subscribe";
            btn.disabled = false;
          }, 3000);
        } else {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || "Subscribe failed");
        }
      } catch {
        btnText.textContent = "Subscribe";
        btn.disabled = false;
        status.textContent = "Something went wrong. Try again?";
        status.classList.add("newsletter-status--err");
      }
    });
  });
</script>

<style>
  .newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .newsletter--inline {
    gap: 0.5rem;
  }

  .newsletter-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    margin: 0 0 0.25rem;
  }

  .newsletter-desc {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .newsletter-inline-label {
    font-size: 0.9375rem;
    color: var(--color-ink-secondary);
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    max-width: 24rem;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    font-size: 0.875rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-ink);
    font-family: var(--font-sans);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .newsletter-input::placeholder {
    color: var(--color-ink-tertiary);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgb(61 82 213 / 0.12);
  }

  .newsletter-btn {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: var(--radius);
    background: var(--color-accent);
    color: white;
    cursor: pointer;
    font-family: var(--font-sans);
    white-space: nowrap;
    transition: background-color 0.15s, transform 0.1s, opacity 0.15s;
    box-shadow: 0 1px 2px rgb(61 82 213 / 0.3);
  }

  .newsletter-btn:hover:not(:disabled) {
    background: #2c42c4;
    transform: translateY(-1px);
  }

  .newsletter-btn:active:not(:disabled) {
    transform: translateY(0);
  }

  .newsletter-btn:disabled {
    opacity: 0.7;
    cursor: default;
  }

  .newsletter-status {
    width: 100%;
    font-size: 0.8125rem;
    line-height: 1.4;
    margin: 0;
    min-height: 1.2em;
  }

  .newsletter-status:empty {
    display: none;
  }

  .newsletter-status--ok {
    color: #16a34a;
  }

  .newsletter-status--err {
    color: #dc2626;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 480px) {
    .newsletter-form {
      max-width: none;
    }

    .newsletter-input {
      width: 100%;
    }

    .newsletter-btn {
      width: 100%;
    }
  }
</style>
