{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://formspec.org/schemas/definition/1.0",
  "title": "Formspec Definition",
  "description": "A Formspec Definition document per the Formspec v1.0 specification.",
  "type": "object",
  "required": [
    "$formspec",
    "url",
    "version",
    "status",
    "title",
    "items"
  ],
  "properties": {
    "$formspec": {
      "type": "string",
      "const": "1.0",
      "description": "Definition specification version. MUST be '1.0'.",
      "examples": ["1.0"],
      "x-lm": {
        "critical": true,
        "intent": "Version pin for definition schema compatibility."
      }
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Canonical URI identifier of the logical form.",
      "examples": ["https://example.gov/forms/annual-report"],
      "x-lm": {
        "critical": true,
        "intent": "Stable identifier of the form across versions."
      }
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Version identifier of this specific Definition document.",
      "examples": ["2025.1.0"],
      "x-lm": {
        "critical": true,
        "intent": "Version component of the immutable (url, version) identity tuple."
      }
    },
    "versionAlgorithm": {
      "type": "string",
      "enum": [
        "semver",
        "date",
        "integer",
        "natural"
      ],
      "default": "semver"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "retired"
      ],
      "description": "Definition lifecycle state.",
      "examples": ["draft", "active"],
      "x-lm": {
        "critical": true,
        "intent": "Controls publication lifecycle and authoring/production usage."
      }
    },
    "derivedFrom": {
      "oneOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "required": ["url"],
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "description": "Parent definition. Either a URI string or an object with url and optional version."
    },
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9\\-]*$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable definition title.",
      "examples": ["Annual Financial Report"],
      "x-lm": {
        "critical": true,
        "intent": "Display name used by authoring and rendering tools."
      }
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Item"
      },
      "description": "Root item tree defining fields, groups, and display nodes.",
      "examples": [
        [
          {
            "key": "projectName",
            "type": "field",
            "label": "Project Name",
            "dataType": "string"
          }
        ]
      ],
      "x-lm": {
        "critical": true,
        "intent": "Primary structural definition of the form content."
      }
    },
    "binds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Bind"
      }
    },
    "shapes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Shape"
      }
    },
    "instances": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/Instance"
      }
    },
    "variables": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Variable"
      }
    },
    "nonRelevantBehavior": {
      "type": "string",
      "enum": [
        "remove",
        "empty",
        "keep"
      ],
      "default": "remove"
    },
    "optionSets": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/OptionSet"
      }
    },
    "screener": {
      "$ref": "#/$defs/Screener"
    },
    "migrations": {
      "$ref": "#/$defs/Migrations"
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^x-"
      }
    },
    "formPresentation": {
      "type": "object",
      "description": "Form-wide presentation defaults per \u00a74.1.1. All properties OPTIONAL and advisory.",
      "additionalProperties": false,
      "properties": {
        "pageMode": {
          "type": "string",
          "enum": [
            "single",
            "wizard",
            "tabs"
          ],
          "default": "single",
          "description": "How top-level groups are paginated."
        },
        "labelPosition": {
          "type": "string",
          "enum": [
            "top",
            "start",
            "hidden"
          ],
          "default": "top",
          "description": "Default label placement for all Fields."
        },
        "density": {
          "type": "string",
          "enum": [
            "compact",
            "comfortable",
            "spacious"
          ],
          "default": "comfortable",
          "description": "Spacing density hint."
        },
        "defaultCurrency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Default ISO 4217 currency code applied to all money fields that do not declare their own currency. When set, the currency input on MoneyInput widgets is pre-filled and locked to this value.",
          "examples": ["USD", "EUR", "GBP"],
          "x-lm": {
            "critical": true,
            "intent": "Prevents authors from repeating the currency code in every money() FEL expression and every MoneyInput component."
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Item": {
      "type": "object",
      "required": [
        "key",
        "type",
        "label"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "group",
            "field",
            "display"
          ]
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "hint": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "group"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "key": true,
              "type": true,
              "label": true,
              "description": true,
              "hint": true,
              "labels": true,
              "extensions": true,
              "children": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/Item"
                }
              },
              "repeatable": {
                "type": "boolean",
                "default": false
              },
              "minRepeat": {
                "type": "integer",
                "minimum": 0
              },
              "maxRepeat": {
                "type": "integer",
                "minimum": 1
              },
              "$ref": {
                "type": "string",
                "format": "uri"
              },
              "keyPrefix": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
              },
              "presentation": {
                "$ref": "#/$defs/Presentation"
              }
            },
            "additionalProperties": false,
            "anyOf": [
              {
                "required": [
                  "children"
                ]
              },
              {
                "required": [
                  "$ref"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "field"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "key": true,
              "type": true,
              "label": true,
              "description": true,
              "hint": true,
              "labels": true,
              "extensions": true,
              "dataType": {
                "type": "string",
                "description": "The semantic data type of the field. Most types map to scalar JSON values. The 'money' type stores a {\"amount\": string, \"currency\": string} object (e.g. {\"amount\": \"50000.00\", \"currency\": \"USD\"}); use the money() FEL function to produce money values.",
                "enum": [
                  "string",
                  "text",
                  "integer",
                  "decimal",
                  "boolean",
                  "date",
                  "dateTime",
                  "time",
                  "uri",
                  "attachment",
                  "choice",
                  "multiChoice",
                  "money"
                ]
              },
              "currency": {
                "type": "string",
                "pattern": "^[A-Z]{3}$",
                "description": "ISO 4217 currency code for this money field. Overrides formPresentation.defaultCurrency. Only meaningful when dataType is 'money'.",
                "examples": ["USD", "EUR"]
              },
              "precision": {
                "type": "integer",
                "minimum": 0
              },
              "prefix": {
                "type": "string"
              },
              "suffix": {
                "type": "string"
              },
              "options": {
                "oneOf": [
                  {
                    "type": "array",
                    "items": {
                      "$ref": "#/$defs/OptionEntry"
                    }
                  },
                  {
                    "type": "string",
                    "format": "uri"
                  }
                ]
              },
              "optionSet": {
                "type": "string"
              },
              "initialValue": {},
              "semanticType": {
                "type": "string"
              },
              "prePopulate": {
                "type": "object",
                "properties": {
                  "instance": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  },
                  "editable": {
                    "type": "boolean",
                    "default": true
                  }
                },
                "required": [
                  "instance",
                  "path"
                ],
                "additionalProperties": false
              },
              "children": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/Item"
                }
              },
              "presentation": {
                "$ref": "#/$defs/Presentation"
              }
            },
            "required": [
              "dataType"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "display"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "key": true,
              "type": true,
              "label": true,
              "description": true,
              "hint": true,
              "labels": true,
              "extensions": true,
              "presentation": {
                "$ref": "#/$defs/Presentation"
              }
            },
            "additionalProperties": false
          }
        }
      ]
    },
    "Bind": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "calculate": {
          "type": "string"
        },
        "relevant": {
          "type": "string"
        },
        "required": {
          "type": "string"
        },
        "readonly": {
          "type": "string"
        },
        "constraint": {
          "type": "string"
        },
        "constraintMessage": {
          "type": "string"
        },
        "default": {},
        "whitespace": {
          "type": "string",
          "enum": [
            "preserve",
            "trim",
            "normalize",
            "remove"
          ],
          "default": "preserve"
        },
        "excludedValue": {
          "type": "string",
          "enum": [
            "preserve",
            "null"
          ],
          "default": "preserve"
        },
        "nonRelevantBehavior": {
          "type": "string",
          "enum": [
            "remove",
            "empty",
            "keep"
          ]
        },
        "disabledDisplay": {
          "type": "string",
          "enum": [
            "hidden",
            "protected"
          ],
          "default": "hidden"
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false
    },
    "Shape": {
      "type": "object",
      "required": [
        "id",
        "target",
        "message"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_\\-]*$"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ],
          "default": "error"
        },
        "constraint": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "context": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Additional context data as FEL expressions. Keys are context names, values are FEL expression strings."
        },
        "activeWhen": {
          "type": "string"
        },
        "timing": {
          "type": "string",
          "enum": [
            "continuous",
            "submit",
            "demand"
          ],
          "default": "continuous"
        },
        "and": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "or": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "not": {
          "type": "string"
        },
        "xone": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "constraint"
          ]
        },
        {
          "required": [
            "and"
          ]
        },
        {
          "required": [
            "or"
          ]
        },
        {
          "required": [
            "not"
          ]
        },
        {
          "required": [
            "xone"
          ]
        }
      ]
    },
    "Instance": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "format": "uri-template"
        },
        "static": {
          "type": "boolean",
          "default": false
        },
        "data": {},
        "schema": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "readonly": {
          "type": "boolean",
          "default": true
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "source"
          ]
        },
        {
          "required": [
            "data"
          ]
        }
      ],
      "additionalProperties": false
    },
    "Variable": {
      "type": "object",
      "required": [
        "name",
        "expression"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
        },
        "expression": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "default": "#"
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false
    },
    "OptionSet": {
      "type": "object",
      "properties": {
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OptionEntry"
          }
        },
        "source": {
          "type": "string",
          "format": "uri"
        },
        "valueField": {
          "type": "string",
          "default": "value"
        },
        "labelField": {
          "type": "string",
          "default": "label"
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "options"
          ]
        },
        {
          "required": [
            "source"
          ]
        }
      ],
      "additionalProperties": false
    },
    "OptionEntry": {
      "type": "object",
      "required": [
        "value",
        "label"
      ],
      "properties": {
        "value": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false
    },
    "Screener": {
      "type": "object",
      "required": [
        "items",
        "routes"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Item"
          }
        },
        "routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Route"
          },
          "minItems": 1
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false
    },
    "Route": {
      "type": "object",
      "required": [
        "condition",
        "target"
      ],
      "properties": {
        "condition": {
          "type": "string"
        },
        "target": {
          "type": "string",
          "format": "uri"
        },
        "label": {
          "type": "string"
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false
    },
    "Migrations": {
      "type": "object",
      "properties": {
        "from": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/MigrationDescriptor"
          }
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false
    },
    "MigrationDescriptor": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "fieldMap": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "source",
              "target",
              "transform"
            ],
            "properties": {
              "source": {
                "type": "string"
              },
              "target": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "transform": {
                "type": "string",
                "enum": [
                  "preserve",
                  "drop",
                  "expression"
                ]
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "defaults": {
          "type": "object"
        },
        "extensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^x-"
          }
        }
      },
      "additionalProperties": false
    },
    "Presentation": {
      "type": "object",
      "description": "Advisory presentation hints per \u00a74.2.5. All properties OPTIONAL.",
      "additionalProperties": true,
      "properties": {
        "widgetHint": {
          "type": "string",
          "description": "Preferred UI control. Compatibility with dataType is defined in spec prose \u00a74.2.5."
        },
        "layout": {
          "type": "object",
          "description": "Spatial arrangement hints.",
          "additionalProperties": false,
          "properties": {
            "flow": {
              "type": "string",
              "enum": [
                "stack",
                "grid",
                "inline"
              ],
              "default": "stack"
            },
            "columns": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12,
              "description": "Column count when flow is 'grid'."
            },
            "colSpan": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12,
              "description": "Columns this item spans in a parent grid."
            },
            "newRow": {
              "type": "boolean",
              "default": false,
              "description": "Force start of a new grid row."
            },
            "collapsible": {
              "type": "boolean",
              "default": false,
              "description": "Whether a group can be collapsed."
            },
            "collapsedByDefault": {
              "type": "boolean",
              "default": false,
              "description": "Initial collapsed state. Ignored if collapsible is not true."
            },
            "page": {
              "type": "string",
              "minLength": 1,
              "description": "Named wizard step or tab. Only meaningful when formPresentation.pageMode is not 'single'."
            }
          }
        },
        "styleHints": {
          "type": "object",
          "description": "Semantic visual tokens \u2014 NOT CSS.",
          "additionalProperties": false,
          "properties": {
            "emphasis": {
              "type": "string",
              "enum": [
                "primary",
                "success",
                "warning",
                "danger",
                "muted"
              ]
            },
            "size": {
              "type": "string",
              "enum": [
                "compact",
                "default",
                "large"
              ],
              "default": "default"
            }
          }
        },
        "accessibility": {
          "type": "object",
          "description": "Accessibility metadata for assistive technologies.",
          "additionalProperties": false,
          "properties": {
            "role": {
              "type": "string",
              "description": "Semantic role hint. Well-known: 'alert', 'status', 'navigation', 'complementary', 'region'."
            },
            "description": {
              "type": "string",
              "description": "Screen-reader-only supplemental description, distinct from Item description."
            },
            "liveRegion": {
              "type": "string",
              "enum": [
                "off",
                "polite",
                "assertive"
              ],
              "default": "off",
              "description": "How aggressively to announce value changes to assistive tech."
            }
          }
        }
      }
    }
  }
}
