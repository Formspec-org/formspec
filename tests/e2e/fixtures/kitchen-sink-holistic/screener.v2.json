{
  "$formspecScreener": "1.0",
  "url": "https://example.org/forms/kitchen-sink/screener",
  "version": "2.0.0",
  "title": "Kitchen Sink Holistic v2 \u2014 Screener",
  "items": [
    {
      "type": "field",
      "dataType": "integer",
      "key": "triageScore",
      "label": "Triage Score"
    }
  ],
  "binds": [
    {
      "path": "triageScore",
      "required": "true"
    }
  ],
  "evaluation": [
    {
      "id": "routing",
      "strategy": "first-match",
      "routes": [
        {
          "condition": "$triageScore >= 50",
          "target": "https://example.org/forms/high-risk",
          "label": "High Risk"
        },
        {
          "condition": "true",
          "target": "https://example.org/forms/standard",
          "label": "Standard"
        }
      ]
    }
  ]
}
