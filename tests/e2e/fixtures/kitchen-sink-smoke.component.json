{
  "$formspecComponent": "1.0",
  "version": "1.0.0",
  "targetDefinition": { "url": "http://example.org/forms/kitchen-sink" },
  "tokens": {
    "primary": "#3b82f6",
    "secondary": "#64748b",
    "radius": "12px"
  },
  "tree": {
    "component": "Wizard",
    "children": [
      {
        "component": "Page",
        "title": "Basic Information",
        "description": "Tell us who you are.",
        "children": [
          {
            "component": "Card",
            "children": [
              { "component": "Heading", "level": 2, "text": "Profile" },
              { "component": "TextInput", "bind": "userName" },
              { "component": "Toggle", "bind": "showAdvanced" }
            ]
          },
          {
            "component": "ConditionalGroup",
            "when": "showAdvanced == true",
            "children": [
              {
                "component": "Alert",
                "severity": "info",
                "text": "You are now editing advanced settings."
              },
              { "component": "Select", "bind": "theme", "placeholder": "Choose a theme", "clearable": true },
              { "component": "Badge", "text": "New Feature", "variant": "success" },
              { "component": "CheckboxGroup", "bind": "notifications", "columns": 2, "selectAll": true }
            ]
          }
        ]
      },
      {
        "component": "Page",
        "title": "Inventory Management",
        "children": [
          {
            "component": "Stack",
            "bind": "inventory",
            "children": [
              { "component": "TextInput", "bind": "itemName", "placeholder": "Item name" },
              { "component": "NumberInput", "bind": "price", "min": 0, "step": 0.01 },
              { "component": "NumberInput", "bind": "quantity", "min": 0, "step": 1 },
              { "component": "NumberInput", "bind": "subtotal", "step": 0.01 }
            ]
          },
          {
            "component": "DataTable",
            "bind": "inventory",
            "showRowNumbers": true,
            "allowAdd": true,
            "allowRemove": true,
            "columns": [
              { "header": "Item", "bind": "itemName" },
              { "header": "Price", "bind": "price" },
              { "header": "Qty", "bind": "quantity" },
              { "header": "Subtotal", "bind": "subtotal" }
            ]
          },
          {
            "component": "Summary",
            "items": [
              { "label": "Grand Total", "bind": "grandTotal" }
            ]
          }
        ]
      },
      {
        "component": "Page",
        "title": "Financials & Schedule",
        "children": [
          {
            "component": "Tabs",
            "tabLabels": ["Money", "Dates"],
            "children": [
              {
                "component": "Stack",
                "children": [
                  { "component": "NumberInput", "bind": "budget", "min": 0, "step": 100 },
                  { "component": "ProgressBar", "bind": "grandTotal", "max": 10000, "showPercent": true }
                ]
              },
              {
                "component": "Grid",
                "columns": 2,
                "children": [
                  { "component": "DatePicker", "bind": "startDate" },
                  { "component": "DatePicker", "bind": "endDate" }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
