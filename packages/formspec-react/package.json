    "@types/react": "^19.0.0",
    "formspec-engine": "*",
    "formspec-layout": "*",
    "happy-dom": "^17.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
